{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(npx tsc --noEmit)",
      "Bash(npm run lint)",
      "Bash(npx eslint *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(netstat *)",
      "PowerShell(Get-Process *)"
    ],
    "ask": [
      "Edit",
      "Write",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(npm install *)",
      "Bash(taskkill *)",
      "PowerShell(Stop-Process *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Bash(cat .env)",
      "Bash(cat **/.env)",
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git branch -D expo-go-backup)",
      "Bash(git branch -d expo-go-backup)",
      "Bash(git push origin --delete expo-go-backup)",
      "Bash(git push origin :expo-go-backup)"
    ]
  }
}
